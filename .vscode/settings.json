{
    "java.compile.nullAnalysis.mode": "automatic",
    "java.debug.settings.onBuildFailureProceed": true,
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.test.editor.enableShortcuts": true,
    "java.test.defaultConfig": "service-tests-local",
    "java.test.config": [
        {
            "name": "service-tests-local",
            "workingDirectory": "${workspaceFolder}/venta-sneackers",
            "vmArgs": "-Dspring.profiles.active=test -Deureka.client.enabled=false -Dspring.cloud.discovery.enabled=false"
        }
    ]
}